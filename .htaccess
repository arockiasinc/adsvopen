<IfModule mod_rewrite.c>
    RewriteEngine On

    # Keep /public out of the browser URL when this app is hosted in a subfolder.
    RewriteCond %{THE_REQUEST} \s/+(.*/)?public/([^\s?]*) [NC]
    RewriteRule ^public/(.*)$ $1 [R=301,L]

    # Don't double-rewrite internal requests already pointing inside public/
    RewriteRule ^public/ - [L]

    # Send everything else into public/ (Laravel's document root)
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
