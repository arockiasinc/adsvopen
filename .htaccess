<IfModule mod_rewrite.c>
    RewriteEngine On

    <IfModule mod_setenvif.c>
        SetEnvIfNoCase Authorization "(.+)" HTTP_AUTHORIZATION=$1
    </IfModule>

    # Handle Authorization Header before the internal rewrite into public/.
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Redirect any request that explicitly contains /public to the clean URL.
    RewriteCond %{THE_REQUEST} \s/+(.*/)?public/([^\s?]*) [NC]
    RewriteRule ^public/?(.*)$ /$1 [R=301,L,NE]

    # Forward every request into the public/ folder (once only — the
    # condition stops it re-prefixing public/public/... into a loop).
    # public/.htaccess + public/index.php take it from there.
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
