<IfModule mod_rewrite.c>
    RewriteEngine On

    <IfModule mod_setenvif.c>
        SetEnvIfNoCase Authorization "(.+)" HTTP_AUTHORIZATION=$1
    </IfModule>

    # Handle Authorization Header before the internal rewrite into public/.
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Redirect any request that explicitly contains /public to the clean URL.
    RewriteCond %{THE_REQUEST} \s/+(.*/)?public/([^\s?]*) [NC]
    RewriteRule ^public/?(.*)$ /$1 [R=301,L,NE]

    # Serve public assets, but let Laravel routes hit the project-root front
    # controller so subfolder in++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++--------++++++++++++++++++++++++++++++++++++++++++++++++++++stalls keep the correct base path.
    RewriteRule ^(build|css|images|js|storage|vendor)/(.*)$ public/$1/$2 [L]
    RewriteRule ^(favicon\.ico|robots\.txt)$ public/$1 [L]

    RewriteRule ^ index.php [L]
</IfModule>
